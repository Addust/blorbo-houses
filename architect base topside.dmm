/obj/item/clothing/suit/armor/vest/duster{
	name = "requiem ranger duster";
	desc = "An armoured, black duster bearing the insignia of what was once Johnson and Company's salvage corps. These were originally standard-issue for the colonial militia of Requiem, but upon the arrival of the NGR, the militia was disbanded. A few veterans from the militia trickled into the NGR, and now serve as marksmen with their distinctive dusters. This example seems to bear the rank insignia of a Captain."
	},
/obj/item/clothing/mask/gas/sechailer,
/obj/item/clothing/glasses/sunglasses/ballistic,
/obj/item/clothing/head/helmet/bulletproof{
	name = "ranger helmet";
	desc = "A bulletproof combat helmet originally used by salvage teams of Johnson and Company, then the Rangers of Requiem's old colonial militia. Much like the dusters, these helmets remain an incredibly rare sight, especially since the militia's disbanding, but some are still held by former Rangers."
	},
