/obj/item/bodypart/chest/ipc/saipc2{
	pixel_x = 2;
	pixel_y = 6;
	desc = "A bulky chest-piece for a full-body prosthetic. Its central components have been replaced with a heavily-armoured lump of black steel bearing the engraved insignia of Johnson & Company, surrounded by twisting wires and interlinking steel cross-beams, and there doesn't seem to be any standard mounts for positronic heads.";
	name = "\improper JC-AC-001-OSU Chassis Core"
	},
/obj/item/bodypart/l_arm/ipc/saipc2{
	pixel_x = 2;
	pixel_y = 6;
	desc = "A sturdy cybernetic arm bearing the insignia of Johnson and Company, bearing an inactive touchscreen display and integrated keyboard just behind the wrist. Various snaking wires are exposed by an open panel behind it.";
	name = "\improper JC-L02-ACU Augment Control Unit-Integrated Manipulator"
	},
/obj/item/bodypart/leg/left/ipc/saipc2{
	pixel_x = 6;
	pixel_y = 1;
	desc = "A standardised cybernetic leg bearing laser-engraved insignia of Johnson & Company. Its motors seem a bit big for the casing.";
	name = "\improper JC-LG02 Leg Type 2"
	},
/obj/item/bodypart/leg/right/ipc/saipc2{
	pixel_x = -1;
	pixel_y = 1;
	desc = "A standardised cybernetic leg bearing laser-engraved insignia of Johnson & Company. Its motors seem a bit big for the casing.";
	name = "\improper JC-LG02 Leg Type 2"
	},
/obj/item/bodypart/r_arm/ipc/custom_saipc2{
	pixel_x = -2;
	pixel_y = 3;
	name = "\improper JC-R04 Combat Manipulator";
	desc = "A bulky cybernetic arm, painted in a blood-red colour scheme reminiscent of the Second Battlegroup - or the old Marauders. It seems fitted with various extra servo-motors and joints to assist in handling lever-action firearms, and its thumb is abnormally long."
	},
/obj/item/computer_hardware/processor_unit{
